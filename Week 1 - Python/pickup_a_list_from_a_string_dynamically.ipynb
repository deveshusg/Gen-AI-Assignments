   "source": [
    "def string_to_list(s):\n",
    "    d=[]\n",
    "    for x in s.strip('[]').split(','):\n",
    "        d.append(x.strip())\n",
    "    return d   \n",
    "\n",
    "s = \"[1, 2, 3, 4]\"\n",
    "output = string_to_list(s)\n",
    "print(output)"
   ]
  }
